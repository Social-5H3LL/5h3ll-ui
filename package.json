{
  "name": "5h3ll-ui",
  "version": "0.1.2",
  "description": "5H3LL-UI — shadcn-compatible components for developers avoiding React",
  "author": "social5h3ll",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "5h3ll-ui",
    "social-5h3ll",
    "ui5h3ll",
    "components",
    "component library",
    "component system",
    "ui",
    "ui kit",
    "shadcn",
    "shadcn/ui",
    "tailwind",
    "tailwindcss",
    "css",
    "html",
    "jinja",
    "nunjucks"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/social-5h3ll/5h3ll-ui.git"
  },
  "bugs": {
    "url": "https://github.com/social-5h3ll/5h3ll-ui/issues"
  },
  "homepage": "https://ui.5h3ll.site",
  "scripts": {
    "build": "node ./scripts/build.js",
    "rules:sync": "node ./scripts/sync-agent-rules.js",
    "docs:build:css": "node ./scripts/build-docs-css.js",
    "docs:build": "npm run docs:build:css && eleventy",
    "docs:dev:css": "node ./scripts/build-docs-css.js --watch",
    "docs:dev:eleventy": "ELEVENTY_ENV=prod eleventy --serve",
    "docs:dev": "concurrently \"npm:docs:dev:css\" \"npm:docs:dev:eleventy\"",
    "landing:build": "npm run docs:build:css && eleventy --config=.eleventy.landing.js",
    "landing:dev": "concurrently \"npm:docs:dev:css\" \"eleventy --serve --config=.eleventy.landing.js --port=8081\"",
    "workers:dev": "npm run docs:build && wrangler dev",
    "workers:deploy": "npm run docs:build && wrangler deploy",
    "workers:preview": "npm run docs:build && wrangler versions upload"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@grimlink/eleventy-plugin-lucide-icons": "^2.1.4",
    "@shikijs/markdown-it": "^4.2.0",
    "@tailwindcss/cli": "^4.1.3",
    "concurrently": "^9.1.2",
    "eleventy-plugin-toc": "^1.1.5",
    "htmx.org": "^2.0.10",
    "lucide-static": "^1.17.0",
    "markdown-it": "^14.2.0",
    "markdown-it-anchor": "^9.2.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.3.0",
    "terser": "^5.42.0",
    "wrangler": "^4.50.0"
  }
}
