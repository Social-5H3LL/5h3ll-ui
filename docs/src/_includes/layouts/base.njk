<!DOCTYPE html>
<html>
<head>
  {# Theme boot — must run before first paint to avoid dark-mode CLS #}
  <style id="ui5h3ll-theme-guard">
    html { color-scheme: light dark; }
    html, body {
      margin: 0;
      background-color: #fff;
      color: #252525;
      font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    html.dark, html.dark body {
      background-color: #252525;
      color: #fafafa;
    }
    #content.htmx-swapping {
      contain: layout style;
      overflow-anchor: none;
    }
  </style>
  <script>
    (() => {
      const root = document.documentElement;

      const applyDark = (dark) => {
        root.classList.toggle('dark', dark);
        root.style.colorScheme = dark ? 'dark' : 'light';
        try { localStorage.setItem('themeMode', dark ? 'dark' : 'light'); } catch (_) {}
      };

      try {
        const stored = localStorage.getItem('themeMode');
        applyDark(stored ? stored === 'dark'
                         : matchMedia('(prefers-color-scheme: dark)').matches);
      } catch (_) {
        applyDark(false);
      }

      try {
        const storedTheme = localStorage.getItem('themeVariant');
        if (storedTheme) root.classList.add(`theme-${storedTheme}`);
      } catch (_) {}

      let styleVariant = 'nova';
      try {
        styleVariant = localStorage.getItem('styleVariant') || 'nova';
      } catch (_) {}
      root.dataset.styleVariant = styleVariant;

      const styleLink = document.createElement('link');
      styleLink.rel = 'stylesheet';
      styleLink.id = 'style-variant-stylesheet';
      styleLink.href = `/assets/styles-${styleVariant}.css`;
      document.head.appendChild(styleLink);

      document.addEventListener('ui5h3ll:theme', (event) => {
        const mode = event.detail?.mode;
        applyDark(mode === 'dark' ? true
                  : mode === 'light' ? false
                  : !root.classList.contains('dark'));
      });
    })();
  </script>
  {# Meta #}
  <meta charset="utf-8">
  <meta http-equiv="Content-Language" content="en">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {# Title & Description #}
  {% set meta_title = title ~ ' | ' ~ site.title  if title else site.title %}
  {% set meta_description = description or site.description %}
  <title>{{ meta_title }}</title>
  <meta name="description" content="{{ meta_description }}"/>
  <meta name="title" content="{{ meta_title }}">
  {% if site.keywords %}<meta name="keywords" content="{{ site.keywords | join(',') }}" />{% endif %}
  {# Favicon #}
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png">
  {# Open Graph / Facebook #}
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:title" content="{{ meta_title }}">
  <meta property="og:description" content="{{ meta_description }}">
  <meta property="og:image" content="{{ site.url }}/assets/social-screenshot.png">
  <meta property="og:site_name" content="{{ site.title }}">
  <meta property="og:locale" content="en_US">
  <meta property="og:author" content="{{ site.author.name }}">
  {# X/Twitter #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content="{{ site.url }}{{ page.url }}">
  <meta name="twitter:title" content="{{ title if title else site.title }}">
  <meta name="twitter:description" content="{{ meta_description }}">
  <meta name="twitter:image" content="{{ site.url }}/assets/social-screenshot.png">
  <meta name="twitter:creator" content="{{ site.author.x }}">
  {# CSS — stylesheet href is injected by theme boot script above #}
  <link rel="preload" href="/assets/fonts/geist/geist-sans-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/geist/geist-sans-latin-500-normal.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/geist/geist-sans-latin-600-normal.woff2" as="font" type="font/woff2" crossorigin>
  {# JS #}
  <script src="/assets/js/ui5h3ll.js?v={{ pkg.version }}" defer></script>
  <script src="/assets/js/command.js?v={{ pkg.version }}" defer></script>
  <script src="/assets/js/combobox.js?v={{ pkg.version }}" defer></script>
  <script src="/assets/js/dropdown-menu.js?v={{ pkg.version }}" defer></script>
  <script src="/assets/js/popover.js?v={{ pkg.version }}" defer></script>
  <script src="/assets/js/range.js?v={{ pkg.version }}" defer></script>
  <script src="/assets/js/select.js?v={{ pkg.version }}" defer></script>
  <script src="/assets/js/sidebar.js?v={{ pkg.version }}" defer></script>
  <script src="/assets/js/tabs.js?v={{ pkg.version }}" defer></script>
  <script src="/assets/js/toast.js?v={{ pkg.version }}" defer></script>
  {# HTMX #}
  <script src="/assets/js/htmx.min.js" defer></script>
  {# Highlight.js #}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/django.min.js"></script>
  <script>
    const highlight = () => {
      if (!window.hljs) return;
      document
        .querySelectorAll('pre code:not([data-highlighted]), code.highlight:not([data-highlighted])')
        .forEach(el => hljs.highlightElement(el));
    };

    if (!window._hljsInit) {
      window._hljsInit = true;
      document.addEventListener('DOMContentLoaded', highlight);
      document.addEventListener('htmx:afterSwap', highlight);
    }
  </script>
  <script>
    const normalizeSidebarPath = (pathname) => pathname.replace(/\/$/, '') || '/';

    const syncSidebarNav = () => {
      const sidebar = document.querySelector('.sidebar');
      if (!sidebar) return;

      const currentPath = normalizeSidebarPath(window.location.pathname);

      sidebar.querySelectorAll('[aria-current="page"]').forEach((el) => {
        el.removeAttribute('aria-current');
      });

      sidebar.querySelectorAll('details[open]').forEach((details) => {
        details.removeAttribute('open');
      });

      let activeLink = null;

      sidebar.querySelectorAll('nav a[href]').forEach((link) => {
        const href = link.getAttribute('href');
        if (!href || href.startsWith('http') || href.startsWith('#')) return;

        const linkPath = normalizeSidebarPath(new URL(href, window.location.href).pathname);
        if (linkPath === currentPath) activeLink = link;
      });

      if (!activeLink) return;

      activeLink.setAttribute('aria-current', 'page');

      const submenu = activeLink.closest('details');
      if (submenu) submenu.setAttribute('open', '');
    };

    const nonHtmlBoostPath = /\.(txt|md|json|xml|pdf|zip|csv|webp|png|jpe?g|gif|svg|ico|js|css)$/i;

    document.addEventListener('htmx:beforeRequest', (event) => {
      const elt = event.detail.elt;
      if (!elt || elt.tagName !== 'A') return;

      const href = elt.getAttribute('href');
      if (!href || href.startsWith('#')) return;

      try {
        const url = new URL(href, window.location.href);
        if (url.origin !== window.location.origin || !nonHtmlBoostPath.test(url.pathname)) return;

        event.preventDefault();
        if (elt.target === '_blank') window.open(url.href, '_blank', 'noopener');
        else window.location.assign(url.href);
      } catch (_) {}
    });

    document.addEventListener('htmx:beforeOnLoad', (event) => {
      const type = (event.detail.xhr?.getResponseHeader('Content-Type') || '').toLowerCase();
      if (!type || type.includes('text/html') || type.includes('application/xhtml+xml')) return;

      event.preventDefault();
      window.location.assign(event.detail.pathInfo.requestPath);
    });

    document.addEventListener('htmx:beforeSwap', (event) => {
      const target = event.detail.target;
      if (!target || target.id !== 'content') return;
      target.classList.add('htmx-swapping');
      target.style.minHeight = `${target.offsetHeight}px`;
    });

    const afterContentSwap = () => {
      if (window.ui5h3ll) window.ui5h3ll.initAll();
      syncSidebarNav();
    };

    document.addEventListener('htmx:afterSwap', afterContentSwap);

    document.addEventListener('htmx:afterSettle', (event) => {
      const target = event.detail.target;
      if (!target || target.id !== 'content') return;
      target.classList.remove('htmx-swapping');
      target.style.minHeight = '';
    });

    document.addEventListener('htmx:historyRestore', afterContentSwap);
  </script>
  {% if head %}{{ head | safe }}{% endif %}
</head>
<body hx-boost="true" hx-target="#content" hx-select="#content" hx-swap="outerHTML show:window:top">
{{ content | safe }}

{% from "toast.njk" import toaster %}
{{ toaster() }}
</body>
</html>
