{% from "macros/integration_showcase.njk" import integration_logo %}

<section class="block-integrations-stacked-icons w-full py-16" aria-labelledby="integrations-stacked-icons-title">
  <div class="mx-auto max-w-4xl px-4 text-center">
    <h2 id="integrations-stacked-icons-title" class="text-3xl font-bold tracking-tight md:text-4xl">
      All types of integration for your team
    </h2>

    <p class="mt-4 text-base text-muted-foreground">
      Connect your favourite apps and services to enhance your experience and boost productivity.
    </p>

    <div class="mt-12 flex justify-center">
      <div class="flex items-center" role="list" aria-label="Featured integrations">
        {% for provider in integrationProviders %}
          {% set provider_tooltip = provider.tooltip or provider.name %}
          <button
            type="button"
            class="btn-icon-outline relative flex size-14 shrink-0 items-center justify-center rounded-full shadow-xs transition-all hover:z-50 hover:scale-110 hover:shadow-md{% if not loop.first %} -ms-3{% endif %}"
            style="z-index: {{ loop.index * 10 }}"
            aria-label="{{ provider_tooltip }}"
            data-tooltip="{{ provider_tooltip }}"
            data-side="top"
            role="listitem"
          >
            {{ integration_logo(
              provider.slug,
              provider.name,
              "size-7 object-contain",
              28,
              28,
              provider.brandLightTone or "light",
              provider.brandDarkTone or "dark"
            ) }}
          </button>
        {% endfor %}
      </div>
    </div>

    <a href="/integrations/" class="btn mt-10">See all integrations</a>
  </div>
</section>
