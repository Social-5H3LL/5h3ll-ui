{% from "macros/integration_showcase.njk" import integration_marquee_tile %}

<section class="block-integrations-marquee-horizontal w-full py-16 lg:py-24" aria-labelledby="integrations-marquee-horizontal-title">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <span class="badge-secondary">Integrations</span>

        <h2 id="integrations-marquee-horizontal-title" class="mt-4 text-3xl font-bold tracking-tight lg:text-4xl">
          Integrate with your favourite apps
        </h2>

        <p class="mt-4 text-muted-foreground">
          Automate and personalize your forms. Connect existing tools from your workflow to build a close knit data management system.
        </p>
      </div>

      <a href="/integrations/" class="btn-outline shrink-0">Browse All Apps</a>
    </div>

    <div class="space-y-4" aria-hidden="true">
      <div class="overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_10%,black_90%,transparent)]">
        <div class="block-integrations-marquee-left flex w-max gap-4">
          {% for repeat in range(0, 3) %}
            {% for provider in integrationProviders %}
              {{ integration_marquee_tile(provider) }}
            {% endfor %}
          {% endfor %}
        </div>
      </div>

      <div class="overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_10%,black_90%,transparent)]">
        <div class="block-integrations-marquee-right flex w-max gap-4">
          {% for repeat in range(0, 3) %}
            {% for provider in integrationProviders | reverse %}
              {{ integration_marquee_tile(provider) }}
            {% endfor %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>
