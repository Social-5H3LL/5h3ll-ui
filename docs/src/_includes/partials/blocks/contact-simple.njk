<section class="block-contact-simple py-20 lg:py-28" aria-labelledby="contact-simple-title">
  <div class="mx-auto max-w-7xl px-4 md:px-6">
    <div class="grid gap-10 lg:grid-cols-2">
      <div class="flex flex-col gap-6">
        <div>
          <span class="badge-secondary inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-medium shadow-sm">
            {% lucide "map-pin", { "class": "size-3.5" } %}
            Contact Us
          </span>
          <h2 id="contact-simple-title" class="mt-4 text-4xl font-bold tracking-tight lg:text-5xl">
            How to get in touch <span class="text-muted-foreground">with us</span>
          </h2>
          <p class="mt-4 max-w-xl text-muted-foreground">
            Have a question, need support, or want to discuss a project? Our team is available across multiple locations around the world.
          </p>
        </div>

        <div class="card overflow-hidden rounded-3xl shadow-xl">
          <div
            class="block-contact-simple-map h-[450px] w-full bg-muted"
            data-contact-simple-map
            role="img"
            aria-label="Map centered on Belfast headquarters, Northern Ireland"
          ></div>
        </div>

        <div class="grid grid-cols-3 gap-4">
          <div class="card p-4 text-center">
            <div class="text-3xl font-bold">7</div>
            <div class="mt-1 text-sm text-muted-foreground">Offices</div>
          </div>
          <div class="card p-4 text-center">
            <div class="text-3xl font-bold">24/7</div>
            <div class="mt-1 text-sm text-muted-foreground">Support</div>
          </div>
          <div class="card p-4 text-center">
            <div class="text-3xl font-bold">50K+</div>
            <div class="mt-1 text-sm text-muted-foreground">Customers</div>
          </div>
        </div>
      </div>

      <div class="space-y-5">
        <article class="card p-6 transition-shadow hover:-translate-y-1 hover:shadow-xl">
          <div class="flex gap-4">
            <div class="flex size-14 items-center justify-center rounded-2xl bg-muted text-2xl">
              {% lucide "calendar", { "class": "size-6" } %}
            </div>
            <div>
              <h3 class="text-lg font-semibold">Book Online</h3>
              <p class="mt-2 text-sm text-muted-foreground">Schedule a consultation directly from our booking system.</p>
              <button type="button" class="btn-outline mt-4">Book Now →</button>
            </div>
          </div>
        </article>

        <article class="card p-6 transition-shadow hover:-translate-y-1 hover:shadow-xl">
          <div class="flex gap-4">
            <div class="flex size-14 items-center justify-center rounded-2xl bg-muted text-2xl">
              {% lucide "phone", { "class": "size-6" } %}
            </div>
            <div>
              <h3 class="text-lg font-semibold">Call Us</h3>
              <p class="mt-2 text-sm text-muted-foreground">Speak directly with a member of our team.</p>
              <a href="tel:+441234567890" class="btn-outline mt-4 inline-flex">+44 1234 567 890</a>
            </div>
          </div>
        </article>

        <article class="card p-6 transition-shadow hover:-translate-y-1 hover:shadow-xl">
          <div class="flex gap-4">
            <div class="flex size-14 items-center justify-center rounded-2xl bg-muted text-2xl">
              {% lucide "map-pin", { "class": "size-6" } %}
            </div>
            <div>
              <h3 class="text-lg font-semibold">Visit Us</h3>
              <p class="mt-2 text-sm text-muted-foreground">Monday – Friday · 8am – 5pm</p>
              <button type="button" class="btn-outline mt-4">Get Directions →</button>
            </div>
          </div>
        </article>

        <div class="rounded-3xl bg-zinc-900 p-8 text-white shadow-xl dark:bg-zinc-950">
          <span class="badge-secondary inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-medium backdrop-blur">Priority Support</span>
          <h3 class="mt-4 text-2xl font-bold">Need help right now?</h3>
          <p class="mt-3 text-zinc-300">Our team usually replies within a few hours during business hours.</p>
          <button type="button" class="btn mt-6 bg-white text-zinc-900 hover:bg-zinc-100">Send Message</button>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="/assets/js/contact-simple-map.js" defer></script>
