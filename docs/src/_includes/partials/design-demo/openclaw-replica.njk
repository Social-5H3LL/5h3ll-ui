  <section class="oc-quickstart" aria-labelledby="oc-quickstart-title" data-oc-demo>
    <h2 id="oc-quickstart-title" class="sr-only">Quick Start</h2>
    <div class="oc-section-label"><span>⟩</span> Quick Start</div>
    <div class="oc-terminal">
      <div class="oc-terminal-bar">
        <div class="oc-terminal-bar-primary">
          <div class="oc-terminal-dots" aria-hidden="true"><span></span><span></span><span></span></div>
          <div class="oc-mode-tabs" role="tablist" aria-label="Install method">
            <button type="button" class="is-active" role="tab" aria-selected="true" data-oc-mode="oneliner">One-liner</button>
            <button type="button" role="tab" aria-selected="false" data-oc-mode="npm">npm</button>
            <button type="button" role="tab" aria-selected="false" data-oc-mode="hackable">Hackable</button>
            <button type="button" role="tab" aria-selected="false" data-oc-mode="apps">Apps</button>
          </div>
        </div>

        <div class="oc-terminal-bar-secondary">
          <div class="oc-toolbar-panel is-active" data-oc-toolbar="oneliner">
            <button type="button" class="oc-beta-btn" data-oc-beta data-beta="false" aria-pressed="false">
              <span class="oc-beta-mark">β</span><span>Beta</span>
            </button>
          </div>

          <div class="oc-toolbar-panel" data-oc-toolbar="npm" hidden>
            <div class="oc-sub-switch" data-oc-pm-switch>
              <button type="button" class="is-active" data-oc-pm="npm">npm</button>
              <button type="button" data-oc-pm="pnpm">pnpm</button>
            </div>
          </div>

          <div class="oc-toolbar-panel" data-oc-toolbar="hackable" hidden>
            <div class="oc-sub-switch" data-oc-hackable-switch>
              <button type="button" class="is-active" data-oc-hackable="installer">installer</button>
              <button type="button" data-oc-hackable="pnpm">pnpm</button>
            </div>
          </div>
        </div>
      </div>

      <div class="oc-terminal-panels">
        <div class="oc-terminal-panel is-active" data-oc-panel="oneliner" role="tabpanel">
          <div class="oc-code-line oc-comment" data-oc-line>
            <span data-oc-oneliner-comment># Works everywhere. On macOS, first run may need an Administrator for Homebrew.</span>
          </div>
          <div class="oc-code-line oc-cmd" data-oc-line>
            <span class="oc-prompt">$</span>
            <span class="oc-cmd-text" data-oc-oneliner-cmd>curl -fsSL https://openclaw.ai/install.sh | bash</span>
            <button type="button" class="oc-copy-line" data-oc-copy="curl -fsSL https://openclaw.ai/install.sh | bash">Copy</button>
          </div>
        </div>

        <div class="oc-terminal-panel" data-oc-panel="npm" role="tabpanel" hidden>
          <div class="oc-code-line oc-comment" data-oc-line># Install OpenClaw</div>
          <div class="oc-code-line oc-cmd" data-oc-line>
            <span class="oc-prompt">$</span>
            <span class="oc-cmd-text" data-oc-pm-install>npm i -g openclaw</span>
            <button type="button" class="oc-copy-line" data-oc-copy="npm i -g openclaw">Copy</button>
          </div>
          <div class="oc-code-line oc-comment" data-oc-line># Meet your lobster</div>
          <div class="oc-code-line oc-cmd" data-oc-line>
            <span class="oc-prompt">$</span>
            <span class="oc-cmd-text">openclaw onboard</span>
            <button type="button" class="oc-copy-line" data-oc-copy="openclaw onboard">Copy</button>
          </div>
        </div>

        <div class="oc-terminal-panel" data-oc-panel="hackable" role="tabpanel" hidden>
          <div data-oc-hackable-panel="installer">
            <div class="oc-code-line oc-comment" data-oc-line># For those who read source code for fun</div>
            <div class="oc-code-line oc-cmd" data-oc-line>
              <span class="oc-prompt">$</span>
              <span class="oc-cmd-text">curl -fsSL https://openclaw.ai/install.sh | bash -s -- --install-method git</span>
              <button type="button" class="oc-copy-line" data-oc-copy="curl -fsSL https://openclaw.ai/install.sh | bash -s -- --install-method git">Copy</button>
            </div>
          </div>
          <div data-oc-hackable-panel="pnpm" hidden>
            <div class="oc-code-line oc-comment" data-oc-line># Source checkouts are pnpm workspaces</div>
            <div class="oc-code-line oc-cmd" data-oc-line>
              <span class="oc-prompt">$</span>
              <span class="oc-cmd-text">git clone https://github.com/openclaw/openclaw.git</span>
              <button type="button" class="oc-copy-line" data-oc-copy="git clone https://github.com/openclaw/openclaw.git">Copy</button>
            </div>
            <div class="oc-code-line oc-cmd" data-oc-line>
              <span class="oc-prompt">$</span>
              <span class="oc-cmd-text">cd openclaw &amp;&amp; corepack enable &amp;&amp; pnpm install</span>
              <button type="button" class="oc-copy-line" data-oc-copy="cd openclaw && corepack enable && pnpm install">Copy</button>
            </div>
            <div class="oc-code-line oc-comment" data-oc-line># Run from source; bundled plugins use extensions/* deps</div>
            <div class="oc-code-line oc-cmd" data-oc-line>
              <span class="oc-prompt">$</span>
              <span class="oc-cmd-text">pnpm openclaw onboard</span>
              <button type="button" class="oc-copy-line" data-oc-copy="pnpm openclaw onboard">Copy</button>
            </div>
          </div>
        </div>

        <div class="oc-terminal-panel oc-apps-panel" data-oc-panel="apps" role="tabpanel" hidden>
          <div class="oc-apps-intro" data-oc-line>
            <span class="oc-apps-tag">Companion Apps (Beta)</span>
            <span class="oc-apps-sub">Native controls for the gateway, chat, setup, and node features.</span>
          </div>
          <div class="oc-apps-grid">
            <article class="oc-apps-card" data-oc-line>
              <span class="oc-apps-platform">macOS</span>
              <a class="oc-btn-primary oc-apps-download" href="https://github.com/openclaw/openclaw/releases/latest" target="_blank" rel="noopener noreferrer">Download macOS</a>
              <span class="oc-apps-meta">Requires macOS 15+ · Universal Binary</span>
            </article>
            <article class="oc-apps-card" data-oc-line>
              <span class="oc-apps-platform">Windows Hub</span>
              <div class="oc-apps-actions">
                <a class="oc-btn-primary oc-apps-download" href="https://github.com/openclaw/openclaw/releases/latest/download/OpenClawCompanion-Setup-x64.exe" target="_blank" rel="noopener noreferrer">Download x64</a>
                <a class="oc-btn-outline oc-apps-download" href="https://github.com/openclaw/openclaw/releases/latest/download/OpenClawCompanion-Setup-arm64.exe" target="_blank" rel="noopener noreferrer">Download ARM64</a>
              </div>
              <span class="oc-apps-meta">Windows 10 20H2+ or Windows 11</span>
            </article>
          </div>
        </div>
      </div>
    </div>
  </section>

