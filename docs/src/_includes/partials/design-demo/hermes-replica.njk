{% from "macros/github_icon.njk" import github_icon %}
{% from "macros/discord_icon.njk" import discord_icon %}
<div class="hm-page" data-hm-demo>
  <header class="hm-header">
    <div class="hm-header-brand">Hermes<br>Agent</div>
    <nav class="hm-header-nav" aria-label="Hermes Agent">
      <a href="https://hermes-agent.nousresearch.com/docs" target="_blank" rel="noopener noreferrer">Docs</a>
      <a href="https://portal.nousresearch.com/" target="_blank" rel="noopener noreferrer">Portal</a>
      <a href="https://hermes-agent.nousresearch.com/desktop" target="_blank" rel="noopener noreferrer">Desktop App</a>
    </nav>
    <div class="hm-header-social">
      <span class="hm-header-social-label">Socials</span>
      <div class="hm-header-social-icons">
        <a href="https://github.com/NousResearch/hermes-agent" target="_blank" rel="noopener noreferrer" title="GitHub" aria-label="GitHub">
          {{ github_icon("hm-social-icon") }}
        </a>
        <a href="https://discord.gg/NousResearch" target="_blank" rel="noopener noreferrer" title="Discord" aria-label="Discord">
          {{ discord_icon("hm-social-icon") }}
        </a>
      </div>
    </div>
  </header>

  <section class="hm-hero">
    <div class="hm-hero-block" data-hm-reveal>
      <p class="hm-eyebrow">Open Source • MIT License</p>
      <h1>The Agent That<br>Grows With You.</h1>
    </div>
    <p class="hm-lead" data-hm-reveal">Not a coding copilot tethered to an IDE or a chatbot wrapper around a single API. An autonomous agent that lives on your server, remembers what it learns, and gets more capable the longer it runs.</p>

    <div class="hm-install" data-hm-reveal>
      <div class="hm-install-tabs" role="tablist" aria-label="Install platform">
        <button type="button" class="is-active" role="tab" aria-selected="true" data-hm-platform="unix">macOS / Linux</button>
        <button type="button" role="tab" aria-selected="false" data-hm-platform="windows">Windows</button>
      </div>

      <div class="hm-install-panel is-active" data-hm-install-panel="unix">
        <div class="hm-install-step" data-hm-step>
          <div class="hm-step-head">
            <span>1. Install</span>
            <button type="button" class="hm-copy" data-hm-copy>Copy</button>
          </div>
          <pre><code>curl -fsSL https://hermes-agent.nousresearch.com/install.sh | bash</code></pre>
        </div>
        <div class="hm-install-step" data-hm-step>
          <div class="hm-step-head">
            <span>2. Configure</span>
            <button type="button" class="hm-copy" data-hm-copy>Copy</button>
          </div>
          <pre><code>hermes setup</code></pre>
        </div>
      </div>

      <div class="hm-install-panel" data-hm-install-panel="windows" hidden>
        <div class="hm-install-step" data-hm-step>
          <div class="hm-step-head">
            <span>1. Install</span>
            <button type="button" class="hm-copy" data-hm-copy>Copy</button>
          </div>
          <pre><code>irm https://hermes-agent.nousresearch.com/install.ps1 | iex</code></pre>
        </div>
        <div class="hm-install-step" data-hm-step>
          <div class="hm-step-head">
            <span>2. Configure</span>
            <button type="button" class="hm-copy" data-hm-copy>Copy</button>
          </div>
          <pre><code>hermes setup</code></pre>
        </div>
      </div>
    </div>
  </section>

  <section class="hm-action">
    <div class="hm-action-label">See It in Action</div>
    <div class="hm-action-grid">
      <div class="hm-terminal">
        <div class="hm-terminal-bar">
          <div class="hm-terminal-dots" aria-hidden="true"><span></span><span></span><span></span></div>
          <span class="hm-terminal-title">Hermes</span>
        </div>
        <div class="hm-terminal-body" data-hm-terminal-output aria-live="polite"></div>
      </div>
      <div class="hm-visual" aria-hidden="true">
        <div class="hm-visual-art"></div>
        <canvas class="hm-visual-canvas"></canvas>
        <img
          class="hm-visual-mark"
          src="https://unpkg.com/@lobehub/icons-static-png@latest/dark/nousresearch.png"
          alt=""
          width="112"
          height="112"
          loading="lazy"
          decoding="async"
        >
        <span class="hm-visual-label">Hermes Agent</span>
      </div>
    </div>
  </section>

  <section class="hm-features" aria-label="Features">
    <div class="hm-features-label">Features</div>
    <div class="hm-feature-grid">
      <article class="hm-feature" data-hm-feature>
        <h2>Lives Where You Do</h2>
        <p>Telegram, Discord, Slack, WhatsApp, Signal, Email, CLI — start on one, pick up on another.</p>
      </article>
      <article class="hm-feature" data-hm-feature>
        <h2>Grows the Longer It Runs</h2>
        <p>Persistent memory and auto-generated skills — it learns your projects and never forgets.</p>
      </article>
      <article class="hm-feature" data-hm-feature>
        <h2>Scheduled Automations</h2>
        <p>Natural language cron scheduling for reports, backups, and briefings through the gateway.</p>
      </article>
      <article class="hm-feature" data-hm-feature>
        <h2>Delegates &amp; Parallelizes</h2>
        <p>Isolated subagents with their own conversations, terminals, and Python RPC scripts.</p>
      </article>
      <article class="hm-feature" data-hm-feature>
        <h2>Real Sandboxing</h2>
        <p>Five backends — local, Docker, SSH, Singularity, Modal — with container hardening.</p>
      </article>
      <article class="hm-feature" data-hm-feature>
        <h2>Full Web &amp; Browser Control</h2>
        <p>Web search, browser automation, vision, image generation, text-to-speech, and multi-model reasoning.</p>
      </article>
    </div>
    <div class="hm-feature-extra" data-hm-extra>
      <div class="hm-feature-grid">
        <article class="hm-feature" data-hm-feature>
          <h2>Multi-Model Reasoning</h2>
          <p>Route tasks across providers and models with configurable fallbacks and cost controls.</p>
        </article>
        <article class="hm-feature" data-hm-feature>
          <h2>Gateway Architecture</h2>
          <p>One persistent gateway coordinates channels, skills, memory, and scheduled jobs.</p>
        </article>
        <article class="hm-feature" data-hm-feature>
          <h2>Open Source Core</h2>
          <p>MIT-licensed agent you can inspect, fork, and deploy on your own infrastructure.</p>
        </article>
      </div>
    </div>
    <button type="button" class="hm-more" data-hm-more aria-expanded="false">More Details ⌄</button>
  </section>

  <footer class="hm-footer">
    <span>Hermes Agent v0.16.0</span>
    <a href="https://nousresearch.com/" target="_blank" rel="noopener noreferrer">Nous Research ↗</a>
    <span>MIT License · 2026</span>
  </footer>
</div>
