      <div>
        <div class="flex items-center gap-2.5">
          {{ brand_logo("size-7 object-contain", 28, 28) }}
          <span class="text-lg font-semibold">5H3LL-UI</span>
        </div>
        <p class="mt-5 text-sm leading-relaxed text-muted-foreground">
          Production-ready UI components and blocks built with 5H3LL-UI, designed to help you ship faster.
