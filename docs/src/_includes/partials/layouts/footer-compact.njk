          <li><a href="/customization/" class="text-xl font-bold hover:text-muted-foreground">Theme Generator</a></li>
          <li><a href="#" class="text-xl font-bold hover:text-muted-foreground">Pricing</a></li>
          <li><a href="#" class="text-xl font-bold hover:text-muted-foreground">FAQ</a></li>
          <li><a href="#" class="text-xl font-bold hover:text-muted-foreground">Contact Us</a></li>
