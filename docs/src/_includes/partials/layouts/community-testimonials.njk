{% from "macros/block_assets.njk" import pravatar %}

<section class="layout-community-testimonials bg-background py-20" aria-labelledby="community-testimonials-title">
  <div class="mx-auto max-w-7xl px-4 md:px-6">
    <div class="grid gap-12 lg:grid-cols-[1fr_1.2fr] lg:items-center">
      <div class="mx-auto flex max-w-2xl flex-col justify-center space-y-4">
        <span class="badge-secondary inline-flex w-fit rounded-full px-3 py-1 text-xs font-semibold">Community</span>
        <h2 id="community-testimonials-title" class="text-4xl font-bold leading-tight">
          We believe in the power of community
        </h2>
        <p class="leading-relaxed text-muted-foreground">
          Our goal is to create a product and service that you're satisfied with and use every day.
          This is why we're constantly improving our services and listening carefully to what our users have to say.
        </p>
        <a href="#" class="btn inline-flex w-fit">Read more testimonials</a>
      </div>

      <div class="layout-community-testimonials-mask flex max-h-[740px] justify-center gap-4 overflow-hidden">
        <div class="layout-community-testimonials-column">
          <div class="layout-community-testimonials-up flex flex-col gap-4">
            {% for repeat in range(0, 2) %}
              {% for item in testimonials.slice(0, 5) %}
                <article class="card max-w-xs p-6">
                  <p>{{ item.quote }}</p>
                  <div class="mt-5 flex items-center gap-3">
                    {{ pravatar(40, item.avatarId, "size-10 rounded-full", item.name) }}
                    <div>
                      <div class="font-medium">{{ item.name }}</div>
                      <div class="text-sm text-muted-foreground">{{ item.role }}</div>
                    </div>
                  </div>
                </article>
              {% endfor %}
            {% endfor %}
          </div>
        </div>

        <div class="layout-community-testimonials-column hidden sm:block">
          <div class="layout-community-testimonials-down flex flex-col gap-4">
            {% for repeat in range(0, 2) %}
              {% for item in testimonials.slice(4, 9) %}
                <article class="card max-w-xs p-6">
                  <p>{{ item.quote }}</p>
                  <div class="mt-5 flex items-center gap-3">
                    {{ pravatar(40, item.avatarId, "size-10 rounded-full", item.name) }}
                    <div>
                      <div class="font-medium">{{ item.name }}</div>
                      <div class="text-sm text-muted-foreground">{{ item.role }}</div>
                    </div>
                  </div>
                </article>
              {% endfor %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
