{% from "macros/block_assets.njk" import brand_logo %}
{% from "macros/github_icon.njk" import github_icon %}

<footer class="layout-footer-serif w-full bg-card">
  <div class="mx-auto grid max-w-6xl grid-cols-1 gap-12 px-6 py-16 md:grid-cols-3">
    <div class="space-y-4 lg:space-y-7">
      <div class="flex items-center gap-3">
        {{ brand_logo("size-8 object-contain", 32, 32) }}
        <span class="font-serif text-2xl font-semibold">5H3LL-UI</span>
      </div>
      <a href="/components/" class="btn-outline inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm no-underline">
        <span>Explore Components</span>
        <span class="flex size-8 items-center justify-center rounded-full border border-border bg-muted">
          {% lucide "arrow-right", { "class": "size-4" } %}
        </span>
      </a>
    </div>

    <div>
      <h3 class="font-serif text-2xl font-semibold">Contact</h3>
      <div class="mt-6 space-y-2 text-sm">contact@social-5h3ll.dev</div>
      <div class="mt-6 flex gap-5">
        <a href="#" aria-label="X">{% lucide "x", { "class": "size-4" } %}</a>
        <a href="#" aria-label="GitHub">{{ github_icon("size-4") }}</a>
        <a href="#" aria-label="Discord">{% lucide "message-circle", { "class": "size-4" } %}</a>
      </div>
    </div>

    <div>
      <h3 class="font-serif text-2xl font-semibold">Quick links</h3>
      <div class="mt-6 grid grid-cols-2 gap-x-8 gap-y-3 text-sm">
        <a href="/components/" class="hover:underline">Components</a>
        <a href="/layouts/overview/" class="hover:underline">Templates</a>
        <a href="/blocks/" class="hover:underline">Blocks</a>
        <a href="#" class="hover:underline">FAQs</a>
        <a href="#" class="hover:underline">Blog</a>
        <a href="#" class="hover:underline">Contact</a>
      </div>
    </div>
  </div>

  <div class="border-t border-border">
    <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-6 py-5">
      <div class="flex flex-wrap items-center gap-3 text-xs text-muted-foreground">
        <span>All rights reserved.</span>
        <span aria-hidden="true">✦</span>
        <a href="/legal/">Privacy &amp; cookies</a>
        <span aria-hidden="true">✦</span>
        <a href="#">Terms &amp; conditions</a>
      </div>
      <span class="text-xs">Built with 5H3LL-UI</span>
    </div>
  </div>
</footer>
