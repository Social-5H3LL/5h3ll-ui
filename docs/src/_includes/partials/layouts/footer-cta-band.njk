{% from "macros/block_assets.njk" import brand_logo %}
{% from "macros/github_icon.njk" import github_icon %}

<div class="layout-footer-cta-band bg-muted">
  <div class="mx-auto max-w-4xl px-6 py-16 text-center">
    <h2 class="text-4xl font-bold sm:text-4xl">Ready to get started</h2>
    <p class="mt-4 text-muted-foreground">Start building with 5H3LL-UI today. No credit card required.</p>
    <a href="/installation/" class="btn mt-8 inline-flex rounded-full px-6 py-3">Try 5H3LL-UI free</a>
  </div>

  <div class="mx-auto max-w-5xl px-6 pb-8">
    <div class="card p-6">
      <div class="grid grid-cols-1 gap-10 sm:grid-cols-3 md:p-2">
        <div>
          <div class="flex items-center gap-2">
            {{ brand_logo("size-6 object-contain", 24, 24) }}
            <span class="font-semibold">5H3LL-UI</span>
          </div>
          <p class="mt-3 text-sm text-muted-foreground">
            Production-ready UI components built with vanilla HTML, CSS, and JavaScript.
          </p>
          <div class="mt-5 flex gap-2.5">
            <a href="https://github.com/social-5h3ll/5h3ll-ui" class="btn-icon-outline size-8" aria-label="GitHub">{{ github_icon("size-4") }}</a>
            <a href="#" class="btn-icon-outline size-8" aria-label="X">{% lucide "x", { "class": "size-4" } %}</a>
          </div>
        </div>
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">Pages</h3>
          <ul class="mt-4 space-y-2.5 text-sm">
            <li><a href="/">Home</a></li>
            <li><a href="/components/">Components</a></li>
            <li><a href="/layouts/overview/">Templates</a></li>
            <li><a href="/introduction/">Docs</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">Information</h3>
          <ul class="mt-4 space-y-2.5 text-sm">
            <li><a href="#">Contact</a></li>
            <li><a href="/legal/">Privacy</a></li>
            <li><a href="#">Terms of use</a></li>
            <li><a href="#">FAQ</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-5 flex flex-wrap items-center justify-between gap-3 px-1 text-sm text-muted-foreground">
      <span>© 2025 5H3LL-UI. Created by <span class="font-semibold text-foreground">Social-5h3ll</span></span>
      <span>Built with <span class="font-semibold text-foreground">5H3LL-UI</span></span>
    </div>
  </div>
</div>
