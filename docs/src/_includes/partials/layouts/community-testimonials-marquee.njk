{% from "macros/block_assets.njk" import pravatar %}

<section class="layout-community-testimonials-marquee overflow-hidden py-16 lg:py-24" aria-labelledby="community-testimonials-marquee-title">
  <div class="mx-auto max-w-7xl px-6">
    <div class="max-w-2xl space-y-4">
      <span class="badge-secondary inline-flex rounded-full px-3 py-1 text-xs font-semibold">Community</span>
      <h2 id="community-testimonials-marquee-title" class="text-4xl font-bold">
        We believe in the power of community
      </h2>
      <p class="leading-relaxed text-muted-foreground">
        Our goal is to create a product and service that people love using every day.
        We listen closely to feedback and continuously improve.
      </p>
      <button type="button" class="btn">Read more testimonials</button>
    </div>
  </div>

  <div class="layout-community-testimonials-marquee-track mt-12 overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_10%,black_90%,transparent)]">
    <div class="block-integrations-marquee-left flex w-max gap-5 px-4">
      {% for repeat in range(0, 2) %}
        {% for item in testimonials %}
          <article class="card w-80 shrink-0 p-6 shadow-xs">
            <div class="mb-3 text-sm text-amber-500" aria-hidden="true">★★★★★</div>
            <p class="mb-6 leading-relaxed text-muted-foreground">{{ item.quote }}</p>
            <div class="flex items-center gap-3">
              {{ pravatar(40, item.avatarId, "size-10 rounded-full", item.name) }}
              <div>
                <div class="font-semibold">{{ item.name }}</div>
                <div class="text-sm text-muted-foreground">{{ item.role }}</div>
              </div>
            </div>
          </article>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>
