<section id="typography" class="w-full scroll-mt-14 rounded-lg border">
  <header class="flex items-center justify-between border-b px-4 py-3">
    <h2 class="text-sm font-medium">Typography</h2>
    <a href="/components/typography/" class="text-muted-foreground hover:text-foreground" data-tooltip="See documentation" data-side="left">
      {% lucide "book-open", { "class": "size-4" } %}
    </a>
  </header>
  <div class="grid gap-6 p-4">
    <div class="grid gap-3">
      <p class="m-0 text-xs font-medium uppercase tracking-wide text-muted-foreground">Text variants</p>
      <div class="grid max-w-xl gap-3">
        <p class="text-xl text-muted-foreground">Lead — A modal dialog that interrupts the user with important content.</p>
        <p class="text-lg font-semibold">Large — Are you absolutely sure?</p>
        <small class="text-sm leading-none font-medium">Small — Email address</small>
        <p class="text-sm text-muted-foreground">Muted — Enter your email address.</p>
        <p class="m-0 text-sm">
          Inline code —
          <code class="relative rounded bg-muted px-[0.3rem] py-[0.2rem] font-mono text-sm font-semibold">pnpm dlx 5h3ll-ui</code>
        </p>
      </div>
    </div>

    <div class="grid gap-3 border-t pt-6">
      <p class="m-0 text-xs font-medium uppercase tracking-wide text-muted-foreground">Article excerpt</p>
      <article class="max-w-xl">
        <h3 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">The Joke Tax</h3>
        <p class="leading-7 [&:not(:first-child)]:mt-4">
          The king's subjects were not amused. They grumbled and complained, but the king was firm:
        </p>
        <blockquote class="mt-4 border-s-2 ps-6 italic">
          "After all," he said, "everyone enjoys a good joke, so it's only fair that they should pay for the privilege."
        </blockquote>
        <ul class="my-4 ms-6 list-disc [&>li]:mt-2">
          <li>1st level of puns: 5 gold coins</li>
          <li>2nd level of jokes: 10 gold coins</li>
          <li>3rd level of one-liners: 20 gold coins</li>
        </ul>
      </article>
    </div>
  </div>
</section>
