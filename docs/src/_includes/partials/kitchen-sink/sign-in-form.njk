<section id="sign-in-form" class="w-full scroll-mt-14 rounded-lg border">
  <header class="flex items-center justify-between border-b px-4 py-3">
    <h2 class="text-sm font-medium">Sign-in form</h2>
    <a href="/blocks/sign-in-form/" class="text-muted-foreground hover:text-foreground" data-tooltip="See documentation" data-side="left">
      {% lucide "book-open", { "class": "size-4" } %}
    </a>
  </header>
  <div class="p-4">
    {% set title_id = "ks-sign-in-title" %}
    {% set email_id = "ks-sign-in-email" %}
    {% set password_id = "ks-sign-in-password" %}
    {% include "partials/blocks/sign-in-form.njk" %}
  </div>
</section>
