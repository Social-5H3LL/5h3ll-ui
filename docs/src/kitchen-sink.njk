{% set kitchen_sink_sections = [
  { label: "Components", id: "kitchen-sink-components", items: components },
  { label: "Blocks", id: "kitchen-sink-blocks", items: blocks },
  { label: "Layouts", id: "kitchen-sink-layouts", items: layouts }
] %}

<div class="kitchen-sink-page">
  <header class="kitchen-sink-hero">
    <p class="kitchen-sink-eyebrow">Examples</p>
    <h1 class="kitchen-sink-title">{{ title }}</h1>
    <p class="kitchen-sink-description">{{ description }}</p>
  </header>

  <div class="kitchen-sink-layout">
    <div class="kitchen-sink-main min-w-0">
      <section id="kitchen-sink-components" class="kitchen-sink-section" aria-labelledby="kitchen-sink-components-heading">
        <header class="kitchen-sink-section-header">
          <h2 id="kitchen-sink-components-heading" class="kitchen-sink-section-title">Components</h2>
          <p class="kitchen-sink-section-desc">Interactive primitives — buttons, inputs, dialogs, and more.</p>
        </header>
        <div class="kitchen-sink-stack" data-kitchen-sink-group="components">
          {% for component in components %}
            {% include "partials/kitchen-sink/" ~ component.id ~ ".njk" %}
          {% endfor %}
        </div>
      </section>

      <section id="kitchen-sink-blocks" class="kitchen-sink-section" aria-labelledby="kitchen-sink-blocks-heading">
        <header class="kitchen-sink-section-header">
          <h2 id="kitchen-sink-blocks-heading" class="kitchen-sink-section-title">Blocks</h2>
          <p class="kitchen-sink-section-desc">Composed page sections built from elements and components.</p>
        </header>
        <div class="kitchen-sink-stack" data-kitchen-sink-group="blocks">
          {% for block in blocks %}
            {% include "partials/kitchen-sink/" ~ block.id ~ ".njk" %}
          {% endfor %}
        </div>
      </section>

      <section id="kitchen-sink-layouts" class="kitchen-sink-section" aria-labelledby="kitchen-sink-layouts-heading">
        <header class="kitchen-sink-section-header">
          <h2 id="kitchen-sink-layouts-heading" class="kitchen-sink-section-title">Layouts</h2>
          <p class="kitchen-sink-section-desc">Full-width marketing shells — scroll horizontally inside each preview when needed.</p>
        </header>
        <div class="kitchen-sink-stack" data-kitchen-sink-group="layouts">
          {% for layout in layouts %}
            {% include "partials/kitchen-sink/" ~ layout.id ~ ".njk" %}
          {% endfor %}
        </div>
      </section>
    </div>

    <aside class="kitchen-sink-aside" aria-label="On this page">
      {{ kitchen_sink_toc(kitchen_sink_sections) }}
    </aside>
  </div>
</div>
