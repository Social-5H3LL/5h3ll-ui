---
layout: layouts/layout.njk
title: Kitchen Sink
description: A collection of all the components available in 5H3LL-UI.
---
{% set components = [
  { label: "Accordion", id: "accordion" },
  { label: "Alert", id: "alert" },
  { label: "Alert Dialog", id: "alert-dialog" },
  { label: "Avatar", id: "avatar" },
  { label: "Badge", id: "badge" },
  { label: "Breadcrumb", id: "breadcrumb" },
  { label: "Button", id: "button" },
  { label: "Card", id: "card" },
  { label: "Checkbox", id: "checkbox" },
  { label: "Combobox", id: "combobox" },
  { label: "Dialog", id: "dialog" },
  { label: "Dropdown Menu", id: "dropdown-menu" },
  { label: "Form", id: "form" },
  { label: "Input", id: "input" },
  { label: "Label", id: "label" },
  { label: "Pagination", id: "pagination" },
  { label: "Popover", id: "popover" },
  { label: "Radio Group", id: "radio-group" },
  { label: "Select", id: "select" },
  { label: "Skeleton", id: "skeleton" },
  { label: "Slider", id: "slider" },
  { label: "Switch", id: "switch" },
  { label: "Table", id: "table" },
  { label: "Tabs", id: "tabs" },
  { label: "Textarea", id: "textarea" },
  { label: "Toast", id: "toast" },
  { label: "Tooltip", id: "tooltip" },
  { label: "Typography", id: "typography" }
] %}

<div class="flex gap-x-10 justify-center">
  <div>
    <header class="space-y-2 mb-8">
      <h1 class="text-3xl font-semibold tracking-tight">{{ title }}</h1>
      <p class="text-muted-foreground">{{ description }}</p>
    </header>
    <div class="grid gap-4 flex-1">
      {% for component in components %}
        {% include "partials/kitchen-sink/" ~ component.id ~ ".njk" %}
      {% endfor %}
    </div>

    <header class="mb-8 mt-12 space-y-2">
      <h2 class="text-2xl font-semibold tracking-tight">Blocks</h2>
      <p class="text-muted-foreground">Composed page sections built from elements and components.</p>
    </header>
    <div class="grid gap-4">
      {% include "partials/kitchen-sink/ai-chat-panel.njk" %}
      {% include "partials/kitchen-sink/stats-row.njk" %}
      {% include "partials/kitchen-sink/sign-in-form.njk" %}
      {% include "partials/kitchen-sink/cta-banner.njk" %}
      {% include "partials/kitchen-sink/integrations-marquee-vertical.njk" %}
      {% include "partials/kitchen-sink/integrations-stacked-icons.njk" %}
      {% include "partials/kitchen-sink/integrations-grid.njk" %}
      {% include "partials/kitchen-sink/integrations-marquee-horizontal.njk" %}
      {% include "partials/kitchen-sink/hero-social-proof.njk" %}
      {% include "partials/kitchen-sink/hero-creative-tools.njk" %}
      {% include "partials/kitchen-sink/cta-grid-background.njk" %}
      {% include "partials/kitchen-sink/cta-learning-split.njk" %}
      {% include "partials/kitchen-sink/newsletter-inline.njk" %}
      {% include "partials/kitchen-sink/newsletter-card.njk" %}
      {% include "partials/kitchen-sink/newsletter-split.njk" %}
      {% include "partials/kitchen-sink/contact-simple.njk" %}
      {% include "partials/kitchen-sink/contact-split.njk" %}
      {% include "partials/kitchen-sink/contact-card.njk" %}
      {% include "partials/kitchen-sink/contact-global.njk" %}
      {% include "partials/kitchen-sink/share-config-modal.njk" %}
    </div>

    <header class="mb-8 mt-12 space-y-2">
      <h2 class="text-2xl font-semibold tracking-tight">Layouts</h2>
      <p class="text-muted-foreground">Full-page shells and marketing layout patterns.</p>
    </header>
    <div class="grid gap-4">
      {% include "partials/kitchen-sink/automation-hero-orbit.njk" %}
      {% include "partials/kitchen-sink/features-grid.njk" %}
      {% include "partials/kitchen-sink/features-tabs.njk" %}
      {% include "partials/kitchen-sink/footer-premium.njk" %}
      {% include "partials/kitchen-sink/footer-columns.njk" %}
      {% include "partials/kitchen-sink/footer-minimal.njk" %}
      {% include "partials/kitchen-sink/footer-serif.njk" %}
      {% include "partials/kitchen-sink/footer-cta-band.njk" %}
      {% include "partials/kitchen-sink/footer-compact.njk" %}
      {% include "partials/kitchen-sink/testimonial-carousel.njk" %}
      {% include "partials/kitchen-sink/testimonial-switcher.njk" %}
      {% include "partials/kitchen-sink/testimonial-showcase.njk" %}
      {% include "partials/kitchen-sink/testimonials-wall.njk" %}
      {% include "partials/kitchen-sink/community-testimonials.njk" %}
      {% include "partials/kitchen-sink/community-testimonials-marquee.njk" %}
    </div>
  </div>
  <div class="hidden text-sm xl:block w-full max-w-[200px]">
    {% from "macros/toc.njk" import toc_nav %}
    {{ toc_nav(components) }}
  </div>
</div>
